# =============================================================================
# multiai2 backend — environment template  (copy to .env and fill real values)
# NEVER commit real secrets. 9Router is INTERNAL ONLY (127.0.0.1).
# =============================================================================

# --- Core ---
APP_NAME=multiai2
ENV=dev
LOG_LEVEL=INFO

# --- PostgreSQL 16 ---
# Use a dedicated DB user with least privilege. Async driver = asyncpg.
DATABASE_URL=postgresql+asyncpg://multiai2:CHANGE_ME@127.0.0.1:5432/multiai2

# --- Redis 7 (cache / locks / queues) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- 9Router (OpenAI-compatible gateway) — INTERNAL ONLY ---
# Binds to 127.0.0.1. The backend is its ONLY client.
# [VERIFY] exact 9Router base URL + auth header key/value against real 9Router docs.
# Do NOT expose this port publicly. Firewall it off.
NINEROUTER_BASE_URL=http://127.0.0.1:20128/v1
NINEROUTER_API_KEY=REPLACE_WITH_9ROUTER_INTERNAL_KEY

# --- FX / pricing ---
FX_BUFFER=1.12                 # 1.10-1.15 over spot
DEFAULT_MARGIN_IN=1.5          # default input margin factor
DEFAULT_MARGIN_OUT=1.8         # default output margin factor (output 3-5x costlier)

# --- Financial safety brakes ---
GLOBAL_DAILY_UPSTREAM_CAP_USD=500.0
PER_MODEL_MARGIN_BRAKE_PCT=5.0
FX_CIRCUIT_BREAKER_PCT=0.05
HOLD_OVERPROVISION=1.1         # reject if balance < estimated_cost * 1.1

# --- Payment (Iranian gateway, abstract behind interface) ---
# Zarinpal is the reference impl; swap freely. Never put provider secret in code.
PAYMENT_PROVIDER=zarinpal
ZARINPAL_MERCHANT_ID=CHANGE_ME
PAYMENT_CALLBACK_URL=https://api.multiai.ir/pay/callback

# --- Telegram bot (Phase later) ---
TELEGRAM_BOT_TOKEN=
